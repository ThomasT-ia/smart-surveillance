# ============================================================================
# FILE DI CONFIGURAZIONE - SISTEMA DI VIDEOSORVEGLIANZA
# ============================================================================
# 
# ISTRUZIONI:
# 1. Copia questo file e rinominalo in ".env"
# 2. Sostituisci tutti i valori di esempio con i tuoi dati reali
# 3. NON committare mai il file ".env" su GitHub (è nel .gitignore)
# 4. Questo file ".env.example" è sicuro da committare (non contiene dati reali)
#
# ============================================================================

# ----------------------------------------------------------------------------
# CHIAVE MASTER PER DECRIPTAZIONE AES-256
# ----------------------------------------------------------------------------
# Questa chiave viene usata per decriptare tutte le password criptate
# GENERA UNA NUOVA CHIAVE con questo comando Python:
#
# python3 -c "from base64 import b64encode; import os; print(b64encode(os.urandom(32)).decode())"
#
MASTER_KEY_256=your_base64_master_key_here_32_bytes

# ----------------------------------------------------------------------------
# CREDENZIALI TELEGRAM (CRIPTATE)
# ----------------------------------------------------------------------------
# Token del bot Telegram - ottienilo da @BotFather su Telegram
# FORMATO: nonce_base64.tag_base64.ciphertext_base64
#
# Per criptare il token usa lo script di criptazione fornito
TELEGRAM_TOKEN_ENC_256=nonce.tag.ciphertext_here

# ID della chat Telegram dove ricevere le notifiche
# Ottienilo chattando con @userinfobot su Telegram
TELEGRAM_CHAT_ID=123456789

# ----------------------------------------------------------------------------
# CREDENZIALI WEB INTERFACE (CRIPTATE)
# ----------------------------------------------------------------------------
# Username per accedere all'interfaccia web (in chiaro, non sensibile)
WEB_USER=admin

# Password per accedere all'interfaccia web (criptata)
# FORMATO: nonce_base64.tag_base64.ciphertext_base64
WEB_PASSWORD_ENC_256=nonce.tag.ciphertext_here

# ----------------------------------------------------------------------------
# CHIAVE SEGRETA FLASK (CRIPTATA)
# ----------------------------------------------------------------------------
# Chiave usata da Flask per firmare le sessioni (cookie)
# FORMATO: nonce_base64.tag_base64.ciphertext_base64
#
# GENERA UNA NUOVA CHIAVE FLASK con:
# python3 -c "import secrets; print(secrets.token_hex(32))"
#
FLASK_SECRET_KEY_ENC_256=nonce.tag.ciphertext_here

# ============================================================================
# CONFIGURAZIONE OPZIONALE (se vuoi personalizzare)
# ============================================================================

# Retention dei video in giorni (default: 30)
# VIDEO_RETENTION_DAYS=30

# Timeout registrazione in secondi (default: 10)
# MOTION_TIMEOUT_SECONDS=10

# Porta del server web (default: 5000)
# FLASK_PORT=5000

# Host del server web (default: 127.0.0.1)
# FLASK_HOST=127.0.0.1
